# لتشغيل النظام أوفلاين مع SQL Server:
# 1. قم بتعيين VITE_USE_LOCAL_API=true
# 2. شغل الـ backend المحلي: cd local-backend && npm run dev

# وضع أوفلاين (SQL Server)
VITE_USE_LOCAL_API=true
VITE_API_URL=http://localhost:3001/api

# وضع أونلاين (Supabase) - اتركه فارغ أو false
# VITE_USE_LOCAL_API=false
